# -----------------------------------------------------------------------------
# INFINITY PRODUCT OS - ENVIRONMENT CONFIGURATION TEMPLATE
# -----------------------------------------------------------------------------
# INSTRUCTIONS:
# 1. Copy this file and rename it to `.env`
# 2. Replace the placeholder values below with your actual local/production secrets.
# 3. NEVER commit the real `.env` file to version control.

# Core Database Credentials
POSTGRES_USER=your_db_user_here
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=infinity_metadata_ledger
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@framework-db:5432/${POSTGRES_DB}

# Distributed Task Queue (Celery/Redis)
CELERY_BROKER_URL=redis://message-broker:6379/0
CELERY_RESULT_BACKEND=redis://message-broker:6379/1

# Inter-Service Routing URLs
CORE_ENGINE_URL=http://core-engine:8081

# Layer 4: Distributed Event Bus (Kafka)
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# Layer 2: External LLM Integration (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here

# Registry display name default: CLIENT (Banking Business Name) or ISO (Technical name)
DEFAULT_DISPLAY_PREFERENCE=CLIENT